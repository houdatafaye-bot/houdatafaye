<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!-- Remplacez "com.votreprojet.PaiementController" par le lien vers votre classe Java -->
<SplitPane dividerPositions="0.55" prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.votreprojet.PaiementController">
    <items>
        <!-- Section Gauche : Historique -->
        <VBox spacing="10" style="-fx-background-color: white;">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <children>
                        <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #10b981;" text="Historique des paiements" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button style="-fx-background-color: #e2e8f0; -fx-text-fill: #000000;" text="Actualiser" />
                    </children>
                </HBox>
                
                <TableView fx:id="paiementTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colFormateur" prefWidth="120" text="Formateur" />
                        <TableColumn fx:id="colPeriode" prefWidth="100" text="Mois / Annee" />
                        <TableColumn fx:id="colHeures" prefWidth="90" text="Heures faites" />
                        <TableColumn fx:id="colMontant" prefWidth="100" text="Montant" />
                        <TableColumn fx:id="colStatut" prefWidth="80" text="Statut" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
                
                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <children>
                        <Button fx:id="btnExport" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold;" text="Exporter Excel" />
                    </children>
                </HBox>
            </children>
        </VBox>

        <!-- Section Droite : Formulaire de Saisie -->
        <VBox spacing="12" style="-fx-background-color: white;">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15" />
            </padding>
            <children>
                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #10b981;" text="Saisie d'un paiement" />

                <Label style="-fx-font-size: 12px; -fx-text-fill: #334155;" text="Formateur" />
                <ComboBox fx:id="formateurCombo" maxWidth="1.7976931348623157E308" promptText="Choisir un formateur" />

                <Label style="-fx-font-size: 12px; -fx-text-fill: #334155;" text="Periode" />
                <HBox spacing="10">
                    <children>
                        <ComboBox fx:id="moisCombo" promptText="Mois" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                        <ComboBox fx:id="anneeCombo" promptText="Annee" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                    </children>
                </HBox>

                <!-- Zone de calcul (encadrée) -->
                <VBox spacing="6" style="-fx-background-color: #eef7f3; -fx-border-color: #cce8df; -fx-border-radius: 6;">
                    <padding>
                        <Insets bottom="10" left="10" right="10" top="10" />
                    </padding>
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #1a3c34;" text="Detail du calcul" />
                        <Label fx:id="lblHeuresPrevues" style="-fx-font-size: 12px;" text="Heures prevues : -H" />
                        <Label fx:id="lblHeuresEffectuees" style="-fx-font-size: 12px;" text="Heures effectuees : -H" />
                        <Label fx:id="lblTauxHoraire" style="-fx-font-size: 12px;" text="Taux horaire : -DH" />
                        <Label fx:id="lblMontantBase" style="-fx-font-weight: bold; -fx-font-size: 12px;" text="Montant base : - DH" />
                    </children>
                </VBox>

                <Label style="-fx-font-size: 12px; -fx-text-fill: #334155;" text="Prime (DH)" />
                <TextField fx:id="primeField" promptText="0" text="0" />

                <Label style="-fx-font-size: 12px; -fx-text-fill: #334155;" text="Retenue (DH)" />
                <TextField fx:id="retenueField" promptText="0" text="0" />

                <Label style="-fx-font-size: 12px; -fx-text-fill: #334155;" text="Montant final (modifiable)" />
                <TextField fx:id="montantFinalField" promptText="Montant DH" style="-fx-background-color: #fef9c3;" />

                <Label style="-fx-font-size: 12px; -fx-text-fill: #334155;" text="Justification (si montant modifie)" />
                <TextField fx:id="justificationField" promptText="Ex: prime exceptionnelle" />

                <VBox spacing="4">
                    <children>
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #475569; -fx-font-weight: bold;" text="Statut du paiement" />
                        <HBox spacing="10">
                            <children>
                                <Button style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 4 12 4 12;" text="Non valide" />
                                <Button style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 4 12 4 12;" text="Valider" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
                
                <Region VBox.vgrow="ALWAYS" /> <!-- Pousse les boutons vers le bas -->

                <HBox alignment="CENTER" spacing="10">
                    <children>
                        <Button fx:id="btnEnregistrer" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15;" text="Enregistrer" />
                        <Button fx:id="btnValiderFinal" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15;" text="Valider" />
                        <Button fx:id="btnSupprimer" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15;" text="Supprimer" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </items>
</SplitPane>