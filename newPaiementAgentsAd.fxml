<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<SplitPane dividerPositions="0.55" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <items>

        <!-- ========== PANEL GAUCHE : LISTE DES AGENTS ========== -->
        <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
            <padding>
                <Insets bottom="18" left="18" right="18" top="18" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #10b981;" text=" Liste des Agents" />
                <Region HBox.hgrow="ALWAYS" />
                <Button style="-fx-background-color: #e2e8f0; -fx-text-fill: #1e293b; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 5 12 5 12;" text="Actualiser" />
            </HBox>

            <Separator style="-fx-background-color: #e2e8f0;" />

            <TableView style="-fx-background-color: white;" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn prefWidth="130" style="-fx-font-weight: bold;" text="Nom complet" />
                    <TableColumn prefWidth="80" style="-fx-font-weight: bold;" text="Type" />
                    <TableColumn prefWidth="90" style="-fx-font-weight: bold;" text="Taux horaire" />
                    <TableColumn prefWidth="80" style="-fx-font-weight: bold;" text="Statut" />
                </columns>
            </TableView>

            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button style="-fx-background-color: #1a4a6f; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 6 15 6 15;" text="Exporter Excel" />
                <Button style="-fx-background-color: #e2e8f0; -fx-text-fill: #1e293b; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 6 15 6 15;" text="Imprimer liste" />
            </HBox>
        </VBox>

        <!-- ========== PANEL DROIT : PAIEMENT MENSUEL ========== -->
        <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
            <padding>
                <Insets bottom="18" left="18" right="18" top="18" />
            </padding>

            <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #10b981;" text=" Fiche de paie mensuelle" />

            <!-- Selection agent et mois -->
            <HBox spacing="15">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 12px; -fx-text-fill: #475569; -fx-font-weight: bold;" text="Agent" />
                    <ComboBox promptText="Selectionner un agent" style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-border-radius: 6;" maxWidth="Infinity" />
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 12px; -fx-text-fill: #475569; -fx-font-weight: bold;" text="Mois de paie" />
                    <HBox spacing="8">
                        <ComboBox promptText="Mois" style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-border-radius: 6;" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                        <ComboBox promptText="Annee" style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-border-radius: 6;" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                    </HBox>
                </VBox>
            </HBox>

            <Separator />

            <!-- TARIFS FIXES -->
            <VBox spacing="8" style="-fx-background-color: #eff6ff; -fx-border-color: #bfdbfe; -fx-border-radius: 10; -fx-background-radius: 10;">
                <padding>
                    <Insets bottom="12" left="12" right="12" top="12" />
                </padding>
                <Label style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #1e40af;" text=" Taux horaire fixes" />
                <HBox spacing="15">
                    <VBox spacing="3">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #475569;" text="Permanent" />
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e40af;" text="30 €/h" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <VBox alignment="CENTER_RIGHT" spacing="3">
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #475569;" text="Vacataire" />
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e40af;" text="45 €/h" />
                    </VBox>
                </HBox>
            </VBox>

            <!-- Infos agent selectionne -->
            <VBox spacing="6" style="-fx-background-color: #f0fdf4; -fx-border-color: #bbf7d0; -fx-border-radius: 10; -fx-background-radius: 10;">
                <padding>
                    <Insets bottom="12" left="12" right="12" top="12" />
                </padding>
                <Label style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #166534;" text="Informations agent" />
                <Label style="-fx-font-size: 12px; -fx-text-fill: #2c3e50;" text="Nom : Sophie Martin" />
                <Label style="-fx-font-size: 12px; -fx-text-fill: #2c3e50;" text="Type : Permanente" />
                <Label style="-fx-font-size: 12px; -fx-text-fill: #15803d; -fx-font-weight: bold;" text="Taux horaire : 30 €/h" />
            </VBox>

            <!-- Heures travaillees dans le mois -->
            <VBox spacing="4">
                <Label style="-fx-font-size: 12px; -fx-text-fill: #475569; -fx-font-weight: bold;" text="Heures travaillees (mois)" />
                <TextField promptText="Ex: 151.67" style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-border-radius: 6;" text="151.67" />
                <Label style="-fx-font-size: 10px; -fx-text-fill: #6b7280;" text="Base legale : 151.67h/mois" />
            </VBox>

            <!-- Prime et retenue -->
            <HBox spacing="15">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 12px; -fx-text-fill: #475569;" text="Prime (€)" />
                    <TextField promptText="0" style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-border-radius: 6;" text="0" />
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 12px; -fx-text-fill: #475569;" text="Retenue (€)" />
                    <TextField promptText="0" style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-border-radius: 6;" text="0" />
                </VBox>
            </HBox>

            <!-- Calcul du salaire mensuel -->
            <VBox spacing="6" style="-fx-background-color: #fefce8; -fx-border-color: #fde047; -fx-border-radius: 10; -fx-background-radius: 10;">
                <padding>
                    <Insets bottom="12" left="12" right="12" top="12" />
                </padding>
                <Label style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #854d0e;" text=" Detail du salaire mensuel" />
                
                <HBox spacing="10">
                    <Label style="-fx-font-size: 12px;" text="Taux horaire :" />
                    <Label style="-fx-font-weight: bold; -fx-font-size: 12px;" text="30 €" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label style="-fx-font-size: 12px;" text="Heures :" />
                    <Label style="-fx-font-weight: bold; -fx-font-size: 12px;" text="151.67 h" />
                </HBox>
                
                <HBox spacing="10">
                    <Label style="-fx-font-size: 12px;" text="Salaire de base :" />
                    <Label style="-fx-font-weight: bold; -fx-font-size: 12px;" text="4 550.10 €" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label style="-fx-font-size: 12px;" text="Prime :" />
                    <Label style="-fx-font-size: 12px;" text="0 €" />
                </HBox>
                
                <HBox spacing="10">
                    <Label style="-fx-font-size: 12px;" text="Retenue :" />
                    <Label style="-fx-font-size: 12px;" text="0 €" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1a4a6f;" text="Net a payer :" />
                    <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #15803d;" text="4 550.10 €" />
                </HBox>
            </VBox>

            <!-- Justification -->
            <VBox spacing="4">
                <Label style="-fx-font-size: 11px; -fx-text-fill: #475569;" text="Justification (prime / retenue)" />
                <TextField promptText="Ex: prime de performance, absence..." style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-border-radius: 6;" />
            </VBox>

            <!-- Statut du paiement -->
            <VBox spacing="4">
                <Label style="-fx-font-size: 12px; -fx-text-fill: #475569; -fx-font-weight: bold;" text="Statut du paiement" />
                <HBox spacing="10">
                    <Button style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 4 12 4 12;" text="Non valide" />
                    <Button style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 4 12 4 12;" text="Valider" />
                </HBox>
            </VBox>

            <!-- Boutons action -->
            <HBox alignment="CENTER" spacing="12">
                <Button style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 20 8 20;" text="Enregistrer" />
                <Button style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 20 8 20;" text="Payer" />
                <Button style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 20 8 20;" text="Annuler" />
            </HBox>

            <!-- Message information -->
            <Label alignment="CENTER" maxWidth="Infinity" style="-fx-font-size: 10px; -fx-text-fill: #6b7280;" text="Taux fixes : Permanent (30€/h) | Vacataire (45€/h)" />
        </VBox>

    </items>
</SplitPane>