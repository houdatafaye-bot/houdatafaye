<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <VBox style="-fx-background-color: #1E40AF;">
            <padding>
                <Insets bottom="10" left="20" right="20" top="15" />
            </padding>
            <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Gestion des Paiements - Formateurs" />
            <Label style="-fx-text-fill: #a3d1c6; -fx-font-size: 12px;" text="Module administratif | Suivi des paiements mensuels" />
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.55">
            <items>
                <VBox spacing="10" style="-fx-background-color: white;">
                    <padding>
                        <Insets bottom="15" left="15" right="15" top="15" />
                    </padding>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #10b981;" text="Historique des paiements" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button style="-fx-background-color: #e2e8f0; -fx-text-fill: #000000;" text="Actualiser" />
                    </HBox>
                    <TableView VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn prefWidth="120" text="Formateur" />
                            <TableColumn prefWidth="100" text="Mois / Annee" />
                            <TableColumn prefWidth="90" text="Heures faites" />
                            <TableColumn prefWidth="100" text="Montant" />
                            <TableColumn prefWidth="80" text="Statut" />
                        </columns>
                    </TableView>
                    <HBox alignment="CENTER_RIGHT" spacing="10">
                        <Button style="-fx-background-color: #10b981; -fx-text-fill: #1e293b;" text="Exporter Excel" />
                    </HBox>
                </VBox>

                <VBox spacing="12" style="-fx-background-color: white;">
                    <padding>
                        <Insets bottom="15" left="15" right="15" top="15" />
                    </padding>
                    <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #10b981;" text="Saisie d'un paiement" />

                    <Label style="-fx-font-size: 12px; -fx-text-fill: #334155;" text="Formateur" />
                    <ComboBox promptText="Choisir un formateur" />

                    <Label style="-fx-font-size: 12px; -fx-text-fill: #334155;" text="Periode" />
                    <HBox spacing="10">
                        <ComboBox promptText="Mois" HBox.hgrow="ALWAYS" />
                        <ComboBox promptText="Annee" HBox.hgrow="ALWAYS" />
                    </HBox>

                    <VBox spacing="6" style="-fx-background-color: #eef7f3; -fx-border-color: #cce8df; -fx-border-radius: 6;">
                        <padding>
                            <Insets bottom="10" left="10" right="10" top="10" />
                        </padding>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #1a3c34;" text="Detail du calcul" />
                        <Label style="-fx-font-size: 12px;" text="Heures prevues : -H" />
                        <Label style="-fx-font-size: 12px;" text="Heures effectuees : -H" />
                        <Label style="-fx-font-size: 12px;" text="Taux horaire : -DH" />
                        <Label style="-fx-font-weight: bold; -fx-font-size: 12px;" text="Montant base : - DH" />
                    </VBox>

                    <Label style="-fx-font-size: 12px; -fx-text-fill: #334155;" text="Prime (DH)" />
                    <TextField promptText="0" text="0" />

                    <Label style="-fx-font-size: 12px; -fx-text-fill: #334155;" text="Retenue (DH)" />
                    <TextField promptText="0" text="0" />

                    <Label style="-fx-font-size: 12px; -fx-text-fill: #334155;" text="Montant final (modifiable)" />
                    <TextField promptText="Montant DH" style="-fx-background-color: #fef9c3;" />

                    <Label style="-fx-font-size: 12px; -fx-text-fill: #334155;" text="Justification (si montant modifie)" />
                    <TextField promptText="Ex: prime exceptionnelle" />
 <!-- Statut du paiement -->
                    <VBox spacing="4">
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #475569; -fx-font-weight: bold;" text="Statut du paiement" />
                        <HBox spacing="10">
                            <Button style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 4 12 4 12;" text="Non valide" />
                            <Button style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 4 12 4 12;" text="Valider" />
                        </HBox>
                    </VBox>
                    <HBox alignment="CENTER" spacing="10">
                        <Button style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold;" text="Enregistrer" />
                        <Button style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold;" text="Valider" />
                        <Button style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold;" text="Supprimer" />
                    </HBox>
                </VBox>
            </items>
        </SplitPane>
    </center>

    <bottom>
        <HBox style="-fx-background-color: white;">
            <padding>
                <Insets bottom="8" left="20" right="20" top="8" />
            </padding>
            <Label style="-fx-text-fill: #000000; -fx-font-size: 11px;" text="Agent connecte : Administrateur" />
            <Region HBox.hgrow="ALWAYS" />
            <Label style="-fx-text-fill: #000000; -fx-font-size: 11px;" text="Pret - Paiement non valide" />
        </HBox>
    </bottom>
</BorderPane>
