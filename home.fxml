<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="900" prefWidth="1250" style="-fx-background-color: #F8FAFC;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">

    <left>
        <VBox prefWidth="260" spacing="5" style="-fx-background-color: #FFFFFF; -fx-border-color: transparent #E2E8F0 transparent transparent; -fx-border-width: 1;">
            
            <padding>
                <Insets bottom="30" left="15" right="15" top="40" />
            </padding>

            <VBox spacing="10" style="-fx-padding: 0 0 40 10;">
                <ImageView fitHeight="99.0" fitWidth="99.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@iisga.png" />
                    </image>
                </ImageView>
                
                <VBox spacing="2">
                    <Label style="-fx-text-fill: #64748B; -fx-font-size: 12px; -fx-font-weight: 500;" text="Gestion Des Paiements">
                  <font>
                     <Font size="20.0" />
                  </font></Label>
                </VBox>
            </VBox>

            <Button alignment="BASELINE_LEFT" maxWidth="Infinity" style="-fx-background-color: #DBEAFE; -fx-text-fill: #1E40AF; -fx-background-radius: 10; -fx-font-weight: bold; -fx-padding: 12 15;" text="Home" />
            <Button alignment="BASELINE_LEFT" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-font-weight: 500; -fx-padding: 12 15;" text="Etudiants" />
            <Button alignment="BASELINE_LEFT" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-font-weight: 500; -fx-padding: 12 15;" text="Formateurs" />
              <Button alignment="BASELINE_LEFT" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-font-weight: 500; -fx-padding: 12 15;" text="Agents administratifs" />
            <Button alignment="BASELINE_LEFT" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-font-weight: 500; -fx-padding: 12 15;" text="Factures" />
            
            <Region VBox.vgrow="ALWAYS" />
            
            <Button maxWidth="Infinity" style="-fx-background-color: #FFF1F2; -fx-text-fill: #BE123C; -fx-background-radius: 10; -fx-font-weight: bold; -fx-padding: 10;" text="Déconnexion" />
        </VBox>
    </left>

    <center>
        <VBox spacing="30" style="-fx-padding: 40;">

            <HBox alignment="CENTER_LEFT" spacing="25" style="-fx-background-color: white; -fx-padding: 25 35; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(30,64,175,0.05), 20, 0, 0, 10);">
                <VBox spacing="8">
                    <Label style="-fx-font-size: 11; -fx-text-fill: #1E40AF; -fx-font-weight: 800; -fx-text-transform: uppercase;" text="Filière" />
                    <ComboBox prefHeight="45" prefWidth="200" promptText="Tous les départements" style="-fx-background-color: #F1F5F9; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10;" />
                </VBox>

                <VBox spacing="8">
                    <Label style="-fx-font-size: 11; -fx-text-fill: #1E40AF; -fx-font-weight: 800; -fx-text-transform: uppercase;" text="Groupe" />
                    <ComboBox prefHeight="45" prefWidth="200" promptText="Groupe sélectionne" style="-fx-background-color: #F1F5F9; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10;" />
                </VBox>

                <VBox spacing="8">
                    <Label style="-fx-font-size: 11; -fx-text-fill: #1E40AF; -fx-font-weight: 800; -fx-text-transform: uppercase;" text="Année" />
                    <ComboBox prefHeight="45" prefWidth="140" promptText="2026" style="-fx-background-color: #F1F5F9; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10;" />
                </VBox>

                <Region HBox.hgrow="ALWAYS" />
                <Button prefHeight="50" prefWidth="150" style="-fx-background-color: #1E40AF; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-font-size: 14;" text="Appliquer les filtres" />
            </HBox>

            <HBox alignment="BOTTOM_LEFT">
                <VBox spacing="5">
                    <Label style="-fx-font-size: 30px; -fx-font-weight: 900; -fx-text-fill: #1E40AF; -fx-letter-spacing: -0.8;" text="Calendrier De Paiement" />
                    <Label style="-fx-text-fill: #64748B; -fx-font-size: 15px;" text="Suivi de l'état d'avancement pour l'année scolaire en cours" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="20" style="-fx-padding: 0 0 10 0;">
                    <HBox alignment="CENTER" spacing="8"><Circle fill="#DCFCE7" radius="6" /><Label style="-fx-text-fill: #1E293B; -fx-font-weight: bold; -fx-font-size: 12;" text="Payé" /></HBox>
                    <HBox alignment="CENTER" spacing="8"><Circle fill="#FEE2E2" radius="6" /><Label style="-fx-text-fill: #1E293B; -fx-font-weight: bold; -fx-font-size: 12;" text="En rettard" /></HBox>
                    <HBox alignment="CENTER" spacing="8"><Circle fill="#F1F5F9" radius="6" /><Label style="-fx-text-fill: #1E293B; -fx-font-weight: bold; -fx-font-size: 12;" text="Prochaine" /></HBox>
                </HBox>
            </HBox>

            <GridPane hgap="20" vgap="20">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="25" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="25" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="25" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="25" />
                </columnConstraints>

                <Button maxWidth="Infinity" prefHeight="130" style="-fx-background-color: #DCFCE7; -fx-text-fill: #166534; -fx-font-size: 18; -fx-font-weight: 800; -fx-background-radius: 18; -fx-border-color: #BBF7D0; -fx-border-width: 2; -fx-border-radius: 18;" text="Janvier" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <Button maxWidth="Infinity" prefHeight="130" style="-fx-background-color: #DCFCE7; -fx-text-fill: #166534; -fx-font-size: 18; -fx-font-weight: 800; -fx-background-radius: 18; -fx-border-color: #BBF7D0; -fx-border-width: 2; -fx-border-radius: 18;" text="Fevrier" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                <Button maxWidth="Infinity" prefHeight="130" style="-fx-background-color: #FEE2E2; -fx-text-fill: #991B1B; -fx-font-size: 18; -fx-font-weight: 800; -fx-background-radius: 18; -fx-border-color: #FECACA; -fx-border-width: 2; -fx-border-radius: 18;" text="Mars" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                <Button maxWidth="Infinity" prefHeight="130" style="-fx-background-color: #F1F5F9; -fx-text-fill: #64748B; -fx-font-size: 18; -fx-font-weight: 700; -fx-background-radius: 18; -fx-border-color: #E2E8F0; -fx-border-width: 2; -fx-border-radius: 18;" text="Avril" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                <Button maxWidth="Infinity" prefHeight="130" style="-fx-background-color: #F1F5F9; -fx-text-fill: #64748B; -fx-font-size: 18; -fx-font-weight: 700; -fx-background-radius: 18; -fx-border-color: #E2E8F0; -fx-border-width: 2; -fx-border-radius: 18;" text="Mai" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <Button maxWidth="Infinity" prefHeight="130" style="-fx-background-color: #F1F5F9; -fx-text-fill: #64748B; -fx-font-size: 18; -fx-font-weight: 700; -fx-background-radius: 18; -fx-border-color: #E2E8F0; -fx-border-width: 2; -fx-border-radius: 18;" text="Juin" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <Button maxWidth="Infinity" prefHeight="130" style="-fx-background-color: #F1F5F9; -fx-text-fill: #64748B; -fx-font-size: 18; -fx-font-weight: 700; -fx-background-radius: 18; -fx-border-color: #E2E8F0; -fx-border-width: 2; -fx-border-radius: 18;" text="Juillet" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                <Button maxWidth="Infinity" prefHeight="130" style="-fx-background-color: #F1F5F9; -fx-text-fill: #64748B; -fx-font-size: 18; -fx-font-weight: 700; -fx-background-radius: 18; -fx-border-color: #E2E8F0; -fx-border-width: 2; -fx-border-radius: 18;" text="Aout" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                <Button maxWidth="Infinity" prefHeight="130" style="-fx-background-color: #F1F5F9; -fx-text-fill: #64748B; -fx-font-size: 18; -fx-font-weight: 700; -fx-background-radius: 18; -fx-border-color: #E2E8F0; -fx-border-width: 2; -fx-border-radius: 18;" text="Septembre" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <Button maxWidth="Infinity" prefHeight="130" style="-fx-background-color: #F1F5F9; -fx-text-fill: #64748B; -fx-font-size: 18; -fx-font-weight: 700; -fx-background-radius: 18; -fx-border-color: #E2E8F0; -fx-border-width: 2; -fx-border-radius: 18;" text="Octobre" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                <Button maxWidth="Infinity" prefHeight="130" style="-fx-background-color: #F1F5F9; -fx-text-fill: #64748B; -fx-font-size: 18; -fx-font-weight: 700; -fx-background-radius: 18; -fx-border-color: #E2E8F0; -fx-border-width: 2; -fx-border-radius: 18;" text="Novembre" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                <Button maxWidth="Infinity" prefHeight="130" style="-fx-background-color: #F1F5F9; -fx-text-fill: #64748B; -fx-font-size: 18; -fx-font-weight: 700; -fx-background-radius: 18; -fx-border-color: #E2E8F0; -fx-border-width: 2; -fx-border-radius: 18;" text="Decembre" GridPane.columnIndex="3" GridPane.rowIndex="2" />
                
                <rowConstraints>
                   <RowConstraints />
                   <RowConstraints />
                   <RowConstraints />
                </rowConstraints>
            </GridPane>

        </VBox>
    </center>

</BorderPane>
